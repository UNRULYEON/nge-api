    "elysia": "latest"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1"
  }
}
